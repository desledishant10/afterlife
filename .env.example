# AWS. Leave blank to use ~/.aws/credentials
AWS_PROFILE=default
AWS_REGION=us-east-1

# GitHub. Token scope requirements:
#   Classic PAT:      read:org, repo
#   Fine-grained PAT (recommended): scoped to one org with
#       Organization permissions  Members: Read
#                                 Administration: Read
#       Repository permissions    Administration: Read   (for deploy keys)
#                                 Metadata: Read
GITHUB_TOKEN=
GITHUB_ORG=

# GitLab. PAT with at least api or read_api scope, group-level membership.
# For self-hosted, set GITLAB_API_URL to https://gitlab.example.com/api/v4.
GITLAB_TOKEN=
GITLAB_GROUP=
GITLAB_API_URL=https://gitlab.com/api/v4

# Identity provider
IDP_PROVIDER=google  # or "okta"

# Google Workspace (service account JSON, with delegated admin user)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_ADMIN_EMAIL=

# GCP IAM. Service account JSON with iam.serviceAccounts.list and
# iam.serviceAccountKeys.list permissions on the target project. The
# account does NOT need domain-wide delegation (different from Workspace).
GCP_PROJECT=
GCP_SERVICE_ACCOUNT_JSON=

# Okta
OKTA_DOMAIN=
OKTA_API_TOKEN=

# Azure / Microsoft Entra ID. App registration with at least User.Read.All
# application permission (admin-consented).
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
