# AWS — leave blank to use ~/.aws/credentials
AWS_PROFILE=default
AWS_REGION=us-east-1

# GitHub — fine-grained PAT with org:read, user:read scopes
GITHUB_TOKEN=
GITHUB_ORG=

# Identity provider
IDP_PROVIDER=google  # or "okta"

# Google Workspace (service account JSON, with delegated admin user)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_ADMIN_EMAIL=

# Okta
OKTA_DOMAIN=
OKTA_API_TOKEN=
